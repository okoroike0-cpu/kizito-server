{
  "name": "omnifetch",
  "version": "3.1.0",
  "description": "Universal video downloader — YouTube, TikTok, Instagram, Twitter/X, Facebook, movie sites and more",
  "main": "server.js",
  "scripts": {
    "postinstall": "pip install -U \"yt-dlp[default,curl-cffi]\" \"https://github.com/coletdjnz/yt-dlp-youtube-oauth2/archive/refs/heads/master.zip\" --break-system-packages -q || true",
    "build": "npm install",
    "start": "node server.js",
    "dev": "nodemon server.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "Michael",
  "license": "ISC"
}